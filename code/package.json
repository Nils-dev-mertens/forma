{
  "name": "forma",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "jest --config jest-working.config.js",
    "test:watch": "jest --config jest-working.config.js --watch",
    "test:coverage": "jest --config jest-working.config.js --coverage",
    "test:auth": "jest --config jest-working.config.js test/auth/",
    "test:api": "jest --config jest-working.config.js test/api/",
    "test:db": "jest --config jest-working.config.js test/db/"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2",
    "jest": "^30.4.2",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.4.11",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
